{
  "name": "blitsbom",
  "private": true,
  "version": "0.1.0-dev",
  "type": "module",
  "license": "MIT",
  "description": "Zero-install CycloneDX SBOM viewer — runs in your browser.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"*.{json,md,html}\"",
    "size-check": "node scripts/size-check.mjs",
    "purity-check": "node scripts/purity-check.mjs",
    "smoke": "node scripts/file-smoke.mjs",
    "e2e": "node scripts/e2e.mjs",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.0",
    "playwright": "^1.47.2",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^6.0.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
